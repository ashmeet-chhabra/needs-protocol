# === Backend (Server-Side Only — NEVER exposed to client) ===

# GEMINI_API_KEY: Required for Gemini AI API calls.
# This key stays on the Express server and is NEVER sent to the browser.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# PORT: Express backend port (default: 3001)
PORT=3001

# === Frontend (Client-Side — Safe to expose) ===

# VITE_API_URL: Backend API base URL. 
# In development, Vite's proxy handles this automatically.
# In production, set this to your deployed backend URL.
# VITE_API_URL="http://localhost:3001"

# === Firebase (Optional — Enables cloud persistence) ===
# These are PUBLIC project identifiers, NOT secrets.
# Security is enforced via Firestore Security Rules.
# If left blank, the app runs in local-only mode (no persistence).

# VITE_FIREBASE_API_KEY=""
# VITE_FIREBASE_AUTH_DOMAIN=""
# VITE_FIREBASE_PROJECT_ID=""
# VITE_FIREBASE_STORAGE_BUCKET=""
# VITE_FIREBASE_MESSAGING_SENDER_ID=""
# VITE_FIREBASE_APP_ID=""
